# Stage 1: Build SUMO from Transcality source branch
FROM ubuntu:22.04 AS sumo-full

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    cmake \
    build-essential \
    libxerces-c-dev \
    libfox-1.6-dev \
    libgdal-dev \
    libproj-dev \
    libgl2ps-dev \
    libglpk-dev \
    libeigen3-dev \
    python3 \
    python3-dev \
    python3-pip \
    unzip \
    gnupg \
    lsb-release \
    && curl -fsSL https://apache.jfrog.io/artifactory/arrow/ubuntu/apache-arrow-apt-source-latest-jammy.deb -o /tmp/arrow.deb \
    && apt-get install -y /tmp/arrow.deb \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    libarrow-dev \
    libparquet-dev \
    && rm -rf /var/lib/apt/lists/* /tmp/arrow.deb

RUN git clone --recursive --branch simreplay-fix https://github.com/Transcality/sumo-transcality.git /tmp/sumo-src \
    && cmake -S /tmp/sumo-src -B /tmp/sumo-src/build -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_STANDARD=20 -DENABLE_PARQUET=ON \
    && cmake --build /tmp/sumo-src/build -j"$(nproc)" \
    && cmake --install /tmp/sumo-src/build

# Stage 2: Minimal runtime  
FROM ubuntu:22.04

# Install runtime deps + Arrow/Parquet + Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    gnupg \
    lsb-release \
    python3-minimal \
    python3-pip \
    libxerces-c3.2 \
    libfox-1.6-0 \
    libgdal30 \
    libproj22 \
    libgl2ps1.4 \
    libglpk40 \
    unzip \
    && curl -fsSL https://apache.jfrog.io/artifactory/arrow/ubuntu/apache-arrow-apt-source-latest-jammy.deb -o /tmp/arrow.deb \
    && apt-get install -y /tmp/arrow.deb \
    && apt-get update \
    && apt-get install -y --no-install-recommends libarrow2400 libparquet2400 \
    && rm -rf /var/lib/apt/lists/* /tmp/arrow.deb

# Copy SUMO binary
COPY --from=sumo-full /usr/local/bin/sumo /usr/bin/sumo

# Copy minimal SUMO data
COPY --from=sumo-full /usr/local/share/sumo/data /usr/share/sumo/data

# Update library cache
RUN ldconfig

# Install boto3
RUN pip3 install --no-cache-dir boto3

# Add upload script
COPY scripts/upload_results.py /scripts/upload_results.py

ENV SUMO_HOME=/usr/share/sumo

# Verify
RUN sumo --version

WORKDIR /workspace
